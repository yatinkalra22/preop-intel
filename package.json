{
  "name": "preop-intel",
  "private": true,
  "packageManager": "npm@11.5.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "deploy": "./scripts/deploy.sh",
    "deploy:prod": "./scripts/deploy.sh prod",
    "deploy:backend": "cd apps/backend && npx serverless deploy",
    "deploy:mcp": "cd apps/mcp-server && npx serverless deploy",
    "deploy:frontend": "cd apps/frontend && vercel --prod",
    "setup:ssm": "./scripts/setup-ssm.sh"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
