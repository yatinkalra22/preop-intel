# ──── Backend ────
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://preop:password@localhost:5432/preop_intel

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# FHIR / MeldRx
FHIR_BASE_URL=https://app.meldrx.com/api/fhir/your-workspace-id
FHIR_CLIENT_ID=your-meldrx-client-id
FHIR_CLIENT_SECRET=your-meldrx-client-secret
SMART_CALLBACK_URL=http://localhost:3001/api/auth/callback

# Prompt Opinion
PROMPT_OPINION_API_KEY=your-prompt-opinion-key
PROMPT_OPINION_WORKSPACE_ID=your-workspace-id

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ──── Frontend ────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_SMART_CLIENT_ID=your-meldrx-client-id
NEXT_PUBLIC_SMART_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_DEMO_MODE=true

# ──── MCP Server ────
MCP_PORT=3002

# ──── AWS (deployment only) ────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
